# 数据库基础配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=123456
DB_NAME=alphapai_reptile
DB_CHARSET=utf8mb4

# 登录信息
LOGIN_MOBILE="+8615627865355"
LOGIN_PASS="etpX+CzwxQ=="

# 启动前的随机等待范围 (单位：秒)
START_DELAY_MIN=0
START_DELAY_MAX=10

# 任务执行的时长范围，建议不要超过30分钟
RUN_DURATION_MIN=20
RUN_DURATION_MAX=25

#爬取列表后休眠时长范围，（单位：秒）
LINK_SLEEP_TIME_MIN=2
LINK_SLEEP_TIME_MAX=5

#切换博主前的强制随机休眠时长范围，（单位：秒）
BREAK_TIME_MIN=1
BREAK_TIME_MAX=4

# --- 避风港/静默期配置 (格式 HH:mm) ---在以下区间内不执行爬取任务
QUIET_START=08:01
QUIET_END=08:00

# 详情任务执行总时长范围（分钟）
DETAIL_TASK_DURATION_MIN=20
DETAIL_TASK_DURATION_MAX=25

# 详情任务启动前随机等待范围（秒）
DETAIL_START_DELAY_MIN=0
DETAIL_START_DELAY_MAX=10

# 每篇文章爬取后的随机休眠范围（秒）
ARTICLE_SLEEP_MIN=5
ARTICLE_SLEEP_MAX=10

# --- 路径配置 (相对于 .env 所在目录) ---
# 存储文章和图片的根目录
DATA_ROOT="files"
# 日志存储目录
REPTILE_DETAILS_LOG_DIR="logs/reptile_details"
SCHEDULER_SKILL_LOG_DIR="logs/scheduler_skill"